{
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "build": {
    "env": {
      "VITE_API_URL": "https://broker-mx-api.onrender.com"
    }
  },
  "rewrites": [
    {
      "source": "/((?!news/|assets/|favicon\\.ico|manifest\\.json|robots\\.txt).*)",
      "destination": "/index.html"
    }
  ]
}
