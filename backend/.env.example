# Puerto del servidor HTTP/WebSocket

PORT=4000



# Origen permitido para CORS (frontend Vite)

CORS_ORIGIN=http://localhost:5173



# Base de datos PostgreSQL (obligatorio — las cuentas persisten aquí).
# Local: docker compose up -d  →  postgresql://postgres:brokermx@localhost:5432/brokermx
# Render: se configura automáticamente con render.yaml

DATABASE_URL="postgresql://postgres:brokermx@localhost:5432/brokermx"



# Secreto para firmar tokens (simulado en este base)

JWT_SECRET=cambia-este-secreto-en-produccion



# Moneda base de la plataforma

BASE_CURRENCY=MXN



# Intervalo (ms) de actualización del feed de precios simulado

PRICE_TICK_MS=1500



# ─── SMS REAL (Twilio) — obligatorio para registro con código ───

# 1) Crea cuenta gratis en https://www.twilio.com

# 2) Consola Twilio → Account SID y Auth Token

# 3) Compra o usa número con SMS (Phone Numbers → Buy a number)

# 4) Cuenta trial: verifica tu celular en Phone Numbers → Verified Caller IDs

# 5) Activa México: Messaging → Geo permissions → Mexico (+52)

#

# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# TWILIO_AUTH_TOKEN=tu_auth_token

# TWILIO_FROM_NUMBER=+1XXXXXXXXXX

#

# Opcional: Messaging Service (recomendado en producción)

# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx



# Solo para pruebas locales SIN Twilio (no usar en producción):

# SMS_MOCK=true

